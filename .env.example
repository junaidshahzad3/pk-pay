# ============================================
# pk-pay — Environment Variables Example
# Copy this file to .env and fill in your keys
# ============================================

# Environment: 'sandbox' | 'production'
PK_PAY_ENV=sandbox

# ─── JazzCash ────────────────────────────────
# Get these from: https://sandbox.jazzcash.com.pk/
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt

# ─── EasyPaisa ───────────────────────────────
# Get these from: https://easypay.easypaisa.com.pk/
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_USERNAME=your_username
EASYPAISA_PASSWORD=your_password

# ─── Stripe ──────────────────────────────────
# Sandbox: use sk_test_... keys
# Production: use sk_live_... keys
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
